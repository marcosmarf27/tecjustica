# TecJustica Parse - Configuracao
# Copie este arquivo para config.env e preencha sua API key:
#   cp config.env.example config.env
#
# Obtenha sua API key em: https://tecjustica-dashboard-production.up.railway.app
#
# IMPORTANTE: esta chave e diferente da chave do MCP TecJustica (plugin principal).
# Mantenha-as separadas: TECJUSTICA_API_KEY (mcp_...) vs TECJUSTICA_PARSE_API_KEY (tjp_...)

TECJUSTICA_PARSE_API_KEY="tjp_sua_chave_aqui"
